<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET"/>

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher_round"
        android:label="NeuroCare"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:usesCleartextTraffic="true"
        android:theme="@style/Theme.MiniV1">

        <!-- Login Activity (Launcher) -->
        <activity
            android:name="com.example.minivone.SplashActivity"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>

        </activity>

        <!-- Other Activities -->
        <activity
            android:name="com.example.minivone.ProfileActivity"
            android:exported="false"/>
        <activity
            android:name="com.example.minivone.HomeActivity"
            android:exported="false"/>
        <activity
            android:name="com.example.minivone.LoginActivity"
            android:exported="false"/>
        <activity
            android:name="com.example.minivone.MainActivity"
            android:exported="false"/>

        <activity
            android:name="com.example.minivone.HistoryActivity"
            android:exported="false"/>

        <activity
            android:name="com.example.minivone.ResultActivity"
            android:exported="false"/>
        <activity
            android:name="com.example.minivone.SignupActivity"
            android:exported="false"/>
        <activity
            android:name="com.example.minivone.LandingActivity"
            android:exported="false"/>
        <activity
            android:name="com.example.minivone.ProfileDataActivity"
            android:exported="false"/>




    </application>

</manifest>